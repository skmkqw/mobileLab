<?xml version="1.0" encoding="utf-8"?>

<androidx.gridlayout.widget.GridLayout xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/favorites_grid"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/inner_margin"
    app:columnCount="3"
    app:useDefaultMargins="true">

    <!-- Row 1 -->
    <Button
        android:id="@+id/main_6_6_board"
        android:width="0dp"
        android:tag="6 6"
        android:onClick="onClickBoardSize"
        android:pointerIcon="context_menu"
        android:text="6 x 6"
        android:textSize="30sp"
        app:icon="@drawable/baseline_rocket_lauch_24"
        app:iconGravity="textTop"
        app:iconPadding="@dimen/icon_padding"
        app:iconSize="54dp"
        app:layout_columnWeight="1"
        app:layout_rowWeight="1" />

    <Space
        android:layout_width="wrap_content"
        android:minWidth="@dimen/inner_margin"
        android:layout_height="wrap_content" />

    <Button
        android:id="@+id/main_4_4_board"
        android:width="0dp"
        android:tag="4 4"
        android:onClick="onClickBoardSize"
        android:pointerIcon="context_menu"
        android:text="4 x 4"
        android:textSize="30sp"
        app:icon="@drawable/baseline_rocket_lauch_24"
        app:iconGravity="textTop"
        app:iconPadding="@dimen/icon_padding"
        app:iconSize="54dp"
        app:layout_columnWeight="1"
        app:layout_rowWeight="1" />

    <!-- Row 2 -->
    <Button
        android:id="@+id/main_4_3_board"
        android:width="0dp"
        android:tag="4 3"
        android:onClick="onClickBoardSize"
        android:pointerIcon="context_menu"
        android:text="4 x 3"
        android:textSize="30sp"
        app:icon="@drawable/baseline_rocket_lauch_24"
        app:iconGravity="textTop"
        app:iconPadding="@dimen/icon_padding"
        app:iconSize="54dp"
        app:layout_columnWeight="1"
        app:layout_rowWeight="1" />

    <Space
        android:layout_width="wrap_content"
        android:minWidth="@dimen/inner_margin"
        android:layout_height="wrap_content" />

    <Button
        android:id="@+id/main_3_2_board"
        android:width="0dp"
        android:tag="3 2"
        android:onClick="onClickBoardSize"
        android:pointerIcon="context_menu"
        android:text="3 x 2"
        android:textSize="30sp"
        app:icon="@drawable/baseline_rocket_lauch_24"
        app:iconGravity="textTop"
        app:iconPadding="@dimen/icon_padding"
        app:iconSize="54dp"
        app:layout_columnWeight="1"
        app:layout_rowWeight="1" />

</androidx.gridlayout.widget.GridLayout>